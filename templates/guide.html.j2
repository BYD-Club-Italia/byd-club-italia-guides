<!DOCTYPE html>
<html lang="it" data-theme="light">
<head>
<meta charset="UTF-8">
<meta name="viewport" content="width=device-width, initial-scale=1.0">
<title>Guida BYD {{ meta.model }} — Firmware · Downgrade · Sideload · Upgrade</title>
<meta name="description" content="Guida completa alla gestione del firmware dell'infotainment BYD {{ meta.model }}: downgrade, sideload e upgrade.">

<link rel="preconnect" href="https://fonts.googleapis.com">
<link rel="preconnect" href="https://fonts.gstatic.com" crossorigin>
<link href="https://fonts.googleapis.com/css2?family=Inter:wght@300;400;500;600;700;800&family=JetBrains+Mono:wght@400;500;600&display=swap" rel="stylesheet">

<style>
/* ============================================================
   DESIGN TOKENS
   ============================================================ */
:root {
  --bg:            #FAFAF9;
  --bg-elevated:   #FFFFFF;
  --bg-subtle:     #F5F5F4;
  --bg-code:       #F4F4F5;
  --text:          #0F172A;
  --text-muted:    #64748B;
  --text-subtle:   #94A3B8;
  --border:        #E2E8F0;
  --border-strong: #CBD5E1;

  --accent:        {{ meta.theme_color | default('#3B82F6') }};
  --accent-dark:   #1D4ED8;
  --accent-soft:   #DBEAFE;

  --warning:       #F59E0B;
  --warning-bg:    #FEF3C7;
  --warning-dark:  #B45309;

  --critical:      #EF4444;
  --critical-bg:   #FEE2E2;
  --critical-dark: #B91C1C;

  --success:       #10B981;
  --success-bg:    #D1FAE5;
  --success-dark:  #047857;

  --info:          #0EA5E9;
  --info-bg:       #E0F2FE;
  --info-dark:     #0369A1;

  --font-sans: 'Inter', -apple-system, BlinkMacSystemFont, 'Segoe UI', system-ui, sans-serif;
  --font-mono: 'JetBrains Mono', 'Consolas', 'Menlo', monospace;

  --radius:    10px;
  --radius-lg: 16px;
  --radius-sm: 6px;
  --shadow:    0 1px 3px rgba(15,23,42,0.06), 0 1px 2px rgba(15,23,42,0.04);
  --shadow-lg: 0 10px 30px rgba(15,23,42,0.08), 0 4px 10px rgba(15,23,42,0.04);

  --sidebar-w: 300px;
}

html[data-theme="dark"] {
  --bg:            #0B1120;
  --bg-elevated:   #111827;
  --bg-subtle:     #1E293B;
  --bg-code:       #1E293B;
  --text:          #F1F5F9;
  --text-muted:    #94A3B8;
  --text-subtle:   #64748B;
  --border:        #1E293B;
  --border-strong: #334155;
  --accent-soft:   rgba(59,130,246,0.15);
  --warning-bg:    rgba(245,158,11,0.12);
  --critical-bg:   rgba(239,68,68,0.12);
  --success-bg:    rgba(16,185,129,0.12);
  --info-bg:       rgba(14,165,233,0.12);
  --shadow:    0 1px 3px rgba(0,0,0,0.3), 0 1px 2px rgba(0,0,0,0.2);
  --shadow-lg: 0 10px 30px rgba(0,0,0,0.4), 0 4px 10px rgba(0,0,0,0.2);
}

*, *::before, *::after { box-sizing: border-box; }
html { scroll-behavior: smooth; scroll-padding-top: 110px; }
body { margin: 0; font-family: var(--font-sans); font-size: 16px; line-height: 1.65;
  color: var(--text); background: var(--bg); -webkit-font-smoothing: antialiased;
  -moz-osx-font-smoothing: grayscale; text-rendering: optimizeLegibility; }
img { max-width: 100%; height: auto; display: block; }
a { color: var(--accent); text-decoration: none; transition: color 0.15s; }
a:hover { color: var(--accent-dark); text-decoration: underline; }
code, kbd { font-family: var(--font-mono); font-size: 0.88em; }
code { background: var(--bg-code); padding: 2px 6px; border-radius: 4px;
  border: 1px solid var(--border); color: var(--text); font-weight: 500; }

.progress-bar { position: fixed; top: 0; left: 0; right: 0; height: 3px;
  background: transparent; z-index: 100; }
.progress-bar__fill { height: 100%;
  background: linear-gradient(90deg, var(--accent) 0%, var(--info) 100%);
  width: 0%; transition: width 0.1s; }

.topbar { position: sticky; top: 0; z-index: 50;
  background: rgba(250,250,249,0.85); backdrop-filter: saturate(180%) blur(12px);
  -webkit-backdrop-filter: saturate(180%) blur(12px);
  border-bottom: 1px solid var(--border);
  display: flex; align-items: center; padding: 14px 24px; gap: 16px; }
html[data-theme="dark"] .topbar { background: rgba(11,17,32,0.85); }
.topbar__title { font-weight: 700; font-size: 15px; letter-spacing: -0.01em;
  display: flex; align-items: center; gap: 10px; }
.topbar__title-logo { width: 30px; height: 30px; border-radius: 8px;
  background: linear-gradient(135deg, var(--accent), var(--info));
  display: flex; align-items: center; justify-content: center;
  color: #fff; font-weight: 800; font-size: 13px; letter-spacing: -0.02em; }
.topbar__spacer { flex: 1; }
.topbar__action { background: none; border: 1px solid var(--border); cursor: pointer;
  width: 36px; height: 36px; border-radius: 8px; color: var(--text-muted);
  display: flex; align-items: center; justify-content: center; transition: all 0.15s; }
.topbar__action:hover { background: var(--bg-subtle); color: var(--text); }
.topbar__action svg { width: 18px; height: 18px; }
.topbar__back { font-size: 13px; color: var(--text-muted); text-decoration: none;
  padding: 6px 10px; border-radius: 6px; transition: all 0.15s; }
.topbar__back:hover { background: var(--bg-subtle); color: var(--text); text-decoration: none; }

.layout { display: grid; grid-template-columns: var(--sidebar-w) 1fr;
  max-width: 1400px; margin: 0 auto; }
.sidebar { position: sticky; top: 64px; height: calc(100vh - 64px);
  padding: 28px 16px 28px 24px; overflow-y: auto; border-right: 1px solid var(--border); }
.sidebar__label { text-transform: uppercase; letter-spacing: 0.08em; font-size: 11px;
  color: var(--text-subtle); font-weight: 600; padding: 4px 12px; margin-bottom: 6px; }
.sidebar__link { display: block; padding: 7px 12px; border-radius: 6px;
  color: var(--text-muted); font-size: 14px; font-weight: 500;
  text-decoration: none; transition: all 0.12s;
  border-left: 2px solid transparent; margin-left: -2px; }
.sidebar__link:hover { color: var(--text); background: var(--bg-subtle); text-decoration: none; }
.sidebar__link.is-active { color: var(--accent); font-weight: 600;
  border-left-color: var(--accent); background: var(--accent-soft); }

.main { padding: 40px 72px 120px; max-width: 860px; min-width: 0; overflow-x: hidden; }
.sidebar::-webkit-scrollbar { width: 6px; }
.sidebar::-webkit-scrollbar-thumb { background: var(--border-strong); border-radius: 3px; }
.sidebar::-webkit-scrollbar-track { background: transparent; }

.hero { position: relative; padding: 48px 56px 56px; border-radius: var(--radius-lg);
  background: linear-gradient(135deg, #1E3A8A 0%, var(--accent) 50%, var(--info) 100%);
  color: #fff; margin-bottom: 48px; overflow: hidden; box-shadow: var(--shadow-lg); }
.hero::before { content: ''; position: absolute; top: 0; right: 0;
  width: 320px; height: 320px;
  background: radial-gradient(circle, rgba(255,255,255,0.15) 0%, transparent 70%);
  border-radius: 50%; pointer-events: none; }
.hero::after { content: ''; position: absolute; bottom: -80px; left: -60px;
  width: 280px; height: 280px;
  background: radial-gradient(circle, rgba(14,165,233,0.3) 0%, transparent 70%);
  border-radius: 50%; pointer-events: none; }
.hero__badge { display: inline-flex; align-items: center; gap: 6px;
  background: rgba(255,255,255,0.15); backdrop-filter: blur(8px);
  padding: 6px 14px; border-radius: 100px; font-size: 12px; font-weight: 600;
  letter-spacing: 0.04em; text-transform: uppercase; margin-bottom: 20px;
  border: 1px solid rgba(255,255,255,0.2); }
.hero__title { font-size: 52px; line-height: 1.05; font-weight: 800;
  letter-spacing: -0.03em; margin: 0 0 12px; }
.hero__title em { font-style: normal; font-weight: 300; opacity: 0.85; }
.hero__subtitle { font-size: 19px; font-weight: 400; opacity: 0.92;
  max-width: 540px; margin: 0 0 32px; line-height: 1.5; }
.hero__meta { display: flex; flex-wrap: wrap; gap: 24px;
  font-size: 13px; position: relative; z-index: 1; }
.hero__meta-item { display: flex; align-items: center; gap: 8px; opacity: 0.9; }

h1.chapter { font-size: 36px; font-weight: 800; letter-spacing: -0.025em;
  margin: 64px 0 8px; padding-left: 20px; position: relative; line-height: 1.15; }
h1.chapter::before { content: ''; position: absolute; left: 0; top: 10px; bottom: 10px;
  width: 5px; border-radius: 4px; background: var(--accent); }
h1.chapter[data-color="warning"]::before  { background: var(--warning); }
h1.chapter[data-color="critical"]::before { background: var(--critical); }
h1.chapter[data-color="success"]::before  { background: var(--success); }
h1.chapter[data-color="info"]::before     { background: var(--info); }

.chapter__num { display: inline-block; font-size: 12px; font-weight: 700;
  letter-spacing: 0.1em; color: var(--accent); text-transform: uppercase;
  margin-bottom: 6px; padding-left: 20px; margin-top: 64px; }
.chapter__num[data-color="warning"]  { color: var(--warning-dark); }
.chapter__num[data-color="critical"] { color: var(--critical-dark); }
.chapter__num[data-color="success"]  { color: var(--success-dark); }
.chapter__num[data-color="info"]     { color: var(--info-dark); }
/* First chapter number: no huge top margin */
.hero + .chapter__num { margin-top: 48px; }
/* When chapter__num precedes h1 directly, collapse the h1 top margin */
.chapter__num + h1.chapter { margin-top: 0; }

h2.section { font-size: 24px; font-weight: 700; letter-spacing: -0.015em;
  margin: 48px 0 16px; color: var(--text); }
h3.subsection { font-size: 18px; font-weight: 600; letter-spacing: -0.01em;
  margin: 32px 0 12px; color: var(--text); }

p { margin: 0 0 16px; }
p strong { font-weight: 600; color: var(--text); }
ul:not([class]), ol:not([class]) { padding-left: 24px; margin: 0 0 20px; }
ul:not([class]) li, ol:not([class]) li { margin-bottom: 8px; }

.callout { border-radius: var(--radius); padding: 18px 22px; margin: 24px 0;
  display: grid; grid-template-columns: auto 1fr; gap: 14px;
  border: 1px solid transparent; box-shadow: var(--shadow);
  overflow: hidden; max-width: 100%; }
@media (max-width: 640px) {
  .callout { padding: 14px 14px; gap: 10px; }
}
.callout__icon { width: 28px; height: 28px; border-radius: 8px;
  display: flex; align-items: center; justify-content: center;
  flex-shrink: 0; font-size: 0; }
.callout__icon svg { width: 16px; height: 16px; color: #fff; }
.callout__body { overflow: hidden; min-width: 0; }
.callout__body > :first-child { margin-top: 0; }
.callout__body > :last-child { margin-bottom: 0; }
.callout__body img { max-width: 100%; height: auto; }
.callout__title { font-weight: 700; font-size: 15px;
  letter-spacing: -0.005em; margin: 0 0 6px; }
.callout--info     { background: var(--info-bg);     border-color: var(--info); }
.callout--info     .callout__icon { background: var(--info); }
.callout--info     .callout__title { color: var(--info-dark); }
.callout--warning  { background: var(--warning-bg);  border-color: var(--warning); }
.callout--warning  .callout__icon { background: var(--warning); }
.callout--warning  .callout__title { color: var(--warning-dark); }
.callout--critical { background: var(--critical-bg); border-color: var(--critical); }
.callout--critical .callout__icon { background: var(--critical); }
.callout--critical .callout__title { color: var(--critical-dark); }
.callout--success  { background: var(--success-bg);  border-color: var(--success); }
.callout--success  .callout__icon { background: var(--success); }
.callout--success  .callout__title { color: var(--success-dark); }

.code-block { position: relative; margin: 20px 0;
  background: var(--bg-code); border: 1px solid var(--border);
  border-radius: var(--radius); overflow: hidden; }
.code-block__header { display: flex; align-items: center; justify-content: space-between;
  padding: 8px 14px; font-size: 12px; color: var(--text-subtle);
  border-bottom: 1px solid var(--border); font-family: var(--font-mono); font-weight: 500; }
.code-block__copy { background: none; border: 1px solid var(--border); cursor: pointer;
  padding: 4px 10px; border-radius: 6px; font-size: 12px;
  color: var(--text-muted); transition: all 0.15s;
  font-family: var(--font-sans); font-weight: 500;
  display: inline-flex; align-items: center; gap: 6px; }
.code-block__copy:hover { background: var(--bg-elevated); color: var(--text); }
.code-block__copy.is-copied { background: var(--success-bg); color: var(--success-dark); border-color: var(--success); }
.code-block__copy svg { width: 13px; height: 13px; }
.code-block pre { margin: 0; padding: 16px 20px; overflow-x: auto;
  font-family: var(--font-mono); font-size: 14px; line-height: 1.6; color: var(--text); }
.code-block pre code { background: none; border: none; padding: 0; font-weight: 400; }

.steps { list-style: none; padding: 0; margin: 24px 0; counter-reset: step; }
.steps > li { position: relative; counter-increment: step;
  padding: 0 0 24px 56px; margin: 0;
  border-left: 2px dashed var(--border); margin-left: 18px; }
.steps > li:last-child { border-left-color: transparent; padding-bottom: 0; }
.steps > li::before { content: counter(step); position: absolute; left: -19px; top: -2px;
  width: 36px; height: 36px; border-radius: 50%;
  background: var(--bg-elevated); color: var(--accent);
  border: 2px solid var(--accent);
  display: flex; align-items: center; justify-content: center;
  font-weight: 700; font-size: 14px; font-family: var(--font-sans); z-index: 1; }

.steps-manual { list-style: none; padding: 0; margin: 24px 0; }
.steps-manual > li { position: relative; padding: 10px 0 10px 56px;
  border-bottom: 1px solid var(--border); }
.steps-manual > li:last-child { border-bottom: none; }
.steps-manual__label { position: absolute; left: 0; top: 10px;
  display: inline-flex; align-items: center; justify-content: center;
  min-width: 44px; height: 28px; padding: 0 10px;
  background: var(--accent-soft); color: var(--accent-dark);
  border-radius: 100px; font-weight: 700; font-size: 13px;
  font-family: var(--font-mono); }

figure {
  margin: 24px 0;
  padding: 12px;
  border-radius: var(--radius-lg);
  background: var(--bg-subtle);
  border: 1px solid var(--border);
  text-align: center;
  /* Mobile-first: piena larghezza */
  width: 100%;
  max-width: 100%;
  overflow: hidden;
}
/* Su desktop, restringe il figure alla larghezza dell'immagine */
@media (min-width: 768px) {
  figure {
    width: fit-content;
    margin: 24px auto;
  }
}
/* Figure dentro callout o card: sempre full-width (non restringe) */
.callout figure, .card figure {
  width: 100%;
  margin: 16px 0;
}
figure img {
  border-radius: var(--radius);
  display: block;
  margin: 0 auto;
  cursor: zoom-in;
  transition: transform 0.2s;
  box-shadow: var(--shadow);
  max-width: 100%;
  height: auto;
}
/* Safety net: su mobile, forza le immagini a non superare mai il contenitore,
   anche se un inline style dovesse dichiarare un max-width più ampio */
@media (max-width: 767px) {
  figure img { max-width: 100% !important; }
}
figure img:hover { transform: scale(1.01); }
figcaption {
  margin-top: 10px;
  font-size: 13px;
  color: var(--text-muted);
  font-style: italic;
  padding: 0 4px;
  word-wrap: break-word;
}

.lightbox { position: fixed; inset: 0; z-index: 1000; display: none;
  background: rgba(15,23,42,0.92); backdrop-filter: blur(8px);
  align-items: center; justify-content: center; padding: 40px; cursor: zoom-out; }
.lightbox.is-open { display: flex; }
.lightbox img { max-width: 100%; max-height: 90vh; border-radius: 8px; }

table { width: 100%; border-collapse: collapse; margin: 24px 0;
  background: var(--bg-elevated); border-radius: var(--radius);
  overflow: hidden; box-shadow: var(--shadow);
  border: 1px solid var(--border); font-size: 14px; }
th, td { padding: 12px 16px; text-align: left; }
th { background: var(--bg-subtle); font-weight: 600; color: var(--text);
  border-bottom: 1px solid var(--border-strong);
  font-size: 13px; text-transform: uppercase; letter-spacing: 0.04em; }
td { border-bottom: 1px solid var(--border); }
tr:last-child td { border-bottom: none; }
tbody tr:hover { background: var(--bg-subtle); }

.card { background: var(--bg-elevated); border: 1px solid var(--border);
  border-radius: var(--radius); padding: 20px 24px; margin: 20px 0;
  box-shadow: var(--shadow); overflow: hidden; }
@media (max-width: 640px) {
  .card { padding: 16px 14px; }
}
.card--highlight { border-left: 4px solid var(--accent); }
.card h3 { margin-top: 0 !important; font-size: 15px; font-weight: 700;
  margin-bottom: 10px; display: flex; align-items: center; gap: 8px; }

.badge { display: inline-flex; align-items: center; gap: 4px;
  padding: 2px 10px; border-radius: 100px; font-size: 12px; font-weight: 600;
  background: var(--bg-subtle); color: var(--text-muted);
  border: 1px solid var(--border); vertical-align: middle; }
.badge--accent   { background: var(--accent-soft); color: var(--accent-dark); border-color: var(--accent); }
.badge--warning  { background: var(--warning-bg); color: var(--warning-dark); border-color: var(--warning); }
.badge--critical { background: var(--critical-bg); color: var(--critical-dark); border-color: var(--critical); }
.badge--success  { background: var(--success-bg); color: var(--success-dark); border-color: var(--success); }
.badge--info     { background: var(--info-bg); color: var(--info-dark); border-color: var(--info); }

.glossary details { border-bottom: 1px solid var(--border); padding: 14px 0; }
.glossary summary { cursor: pointer; font-weight: 600; font-size: 15px;
  list-style: none; display: flex; align-items: center; gap: 10px; color: var(--text); }
.glossary summary::-webkit-details-marker { display: none; }
.glossary summary::before { content: '+'; display: inline-flex; align-items: center;
  justify-content: center; width: 22px; height: 22px; border-radius: 6px;
  background: var(--bg-subtle); color: var(--text-muted);
  font-weight: 600; font-size: 14px; transition: all 0.15s; }
.glossary details[open] summary::before { content: '−'; background: var(--accent-soft); color: var(--accent-dark); }
.glossary details > div { margin-top: 10px; padding-left: 32px; color: var(--text-muted); line-height: 1.65; }

.workflow { display: flex; align-items: stretch; gap: 0; margin: 32px 0; flex-wrap: wrap; }
.workflow__step { flex: 1; min-width: 140px; padding: 16px 12px; text-align: center;
  background: var(--bg-elevated); border: 1px solid var(--border);
  border-radius: var(--radius); position: relative; box-shadow: var(--shadow); }
.workflow__step-num { display: inline-flex; align-items: center; justify-content: center;
  width: 28px; height: 28px; border-radius: 50%;
  background: var(--accent-soft); color: var(--accent-dark);
  font-weight: 700; font-size: 13px; margin-bottom: 8px; }
.workflow__step-title { font-weight: 600; font-size: 14px; margin: 0 0 2px; }
.workflow__step-desc  { font-size: 12px; color: var(--text-muted); }
.workflow__arrow { display: flex; align-items: center; padding: 0 4px; color: var(--accent); font-weight: 700; }

.checklist { list-style: none; padding: 0; margin: 16px 0; }
.checklist li { padding: 10px 0 10px 36px; position: relative;
  border-bottom: 1px solid var(--border); font-size: 14px;
  cursor: pointer; user-select: none; }
.checklist li:last-child { border-bottom: none; }
.checklist li::before { content: ''; position: absolute; left: 0; top: 12px;
  width: 20px; height: 20px; border: 2px solid var(--border-strong);
  border-radius: 5px; background: var(--bg-elevated); transition: all 0.15s; }
.checklist li.is-checked { color: var(--text-muted); text-decoration: line-through; }
.checklist li.is-checked::before { background: var(--success); border-color: var(--success);
  content: '✓'; color: #fff; font-size: 13px; font-weight: 700;
  display: flex; align-items: center; justify-content: center; line-height: 1; }

.footer { margin-top: 96px; padding-top: 32px; border-top: 1px solid var(--border);
  color: var(--text-subtle); font-size: 13px;
  display: flex; justify-content: space-between; align-items: center;
  flex-wrap: wrap; gap: 16px; }

@media (max-width: 1024px) {
  .layout { grid-template-columns: 1fr; }
  .sidebar { position: fixed; left: -100%; top: 64px; width: 280px;
    height: calc(100vh - 64px); background: var(--bg);
    border-right: 1px solid var(--border); z-index: 40;
    transition: left 0.25s; padding: 20px; }
  .sidebar.is-open { left: 0; box-shadow: var(--shadow-lg); }
  .main { padding: 32px 24px 96px; }
  .hero { padding: 36px 32px 40px; }
  .hero__title { font-size: 38px; }
}
@media (max-width: 640px) {
  .main { padding: 24px 16px 80px; }
  .hero__title { font-size: 30px; }
  .hero__subtitle { font-size: 16px; }
  h1.chapter { font-size: 28px; }
  h2.section { font-size: 20px; }
}
.menu-toggle { display: none; }
@media (max-width: 1024px) { .menu-toggle { display: flex; } }

@media print {
  html, body { background: #fff !important; }
  .topbar, .sidebar, .progress-bar, .topbar__action, .menu-toggle,
  .code-block__copy, .lightbox, .topbar__back { display: none !important; }
  .layout { display: block; max-width: none; }
  .main { padding: 0; max-width: none; }
  .hero { box-shadow: none; page-break-after: always;
    margin: 0; border-radius: 0;
    min-height: 260mm; display: flex; flex-direction: column; justify-content: center;
    padding: 80px 56px; }
  .hero__title { font-size: 64px; }
  .hero__subtitle { font-size: 21px; max-width: 580px; }
  .glossary details > div { display: block !important; }
  .glossary summary::before { display: none !important; }
  .glossary summary { cursor: default; }
  .print-hide { display: none !important; }
  .checklist li { cursor: default; }
  /* Chapter number + h1 should stay together and break before */
  .chapter__num { page-break-before: always; page-break-after: avoid; }
  .chapter__num + h1.chapter { page-break-before: avoid; page-break-after: avoid; }
  /* First chapter number: no break before (it follows the cover hero) */
  .hero + .chapter__num { page-break-before: auto; }
  h1.chapter { page-break-after: avoid; }
  h2.section, h3.subsection { page-break-after: avoid; }
  figure, .callout, .card, .code-block, table { page-break-inside: avoid; }
  .steps > li, .steps-manual > li { page-break-inside: avoid; }
  a { color: var(--accent); text-decoration: none; }
  a[href^="http"]::after { content: " (" attr(href) ")"; font-size: 0.8em;
    color: var(--text-subtle); word-break: break-all; }
  .footer { page-break-before: avoid; }
  .workflow__step { padding: 12px 8px; min-width: 110px; }
  .workflow__step-title { font-size: 13px; }
  .workflow__step-desc { font-size: 11px; }
  .workflow__arrow { padding: 0 2px; font-size: 13px; }
}
</style>
</head>
<body>

<div class="progress-bar"><div class="progress-bar__fill" id="progress"></div></div>

<header class="topbar">
  <button class="topbar__action menu-toggle" id="menuToggle" aria-label="Apri indice">
    <svg viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round"><line x1="3" y1="12" x2="21" y2="12"/><line x1="3" y1="6" x2="21" y2="6"/><line x1="3" y1="18" x2="21" y2="18"/></svg>
  </button>
  <a href="index.html" class="topbar__back" title="Tutte le guide">← Tutte le guide</a>
  <div class="topbar__title">
    <div class="topbar__title-logo">BYD</div>
    <span>Guida {{ meta.model }}</span>
  </div>
  <div class="topbar__spacer"></div>
  <button class="topbar__action" id="printBtn" title="Stampa o salva come PDF">
    <svg viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round"><polyline points="6 9 6 2 18 2 18 9"/><path d="M6 18H4a2 2 0 0 1-2-2v-5a2 2 0 0 1 2-2h16a2 2 0 0 1 2 2v5a2 2 0 0 1-2 2h-2"/><rect x="6" y="14" width="12" height="8"/></svg>
  </button>
  <button class="topbar__action" id="themeToggle" aria-label="Cambia tema">
    <svg class="theme-icon-light" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round"><circle cx="12" cy="12" r="4"/><path d="M12 2v2M12 20v2M4.93 4.93l1.41 1.41M17.66 17.66l1.41 1.41M2 12h2M20 12h2M6.34 17.66l-1.41 1.41M19.07 4.93l-1.41 1.41"/></svg>
    <svg class="theme-icon-dark" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round" style="display:none"><path d="M21 12.79A9 9 0 1 1 11.21 3 7 7 0 0 0 21 12.79z"/></svg>
  </button>
</header>

<div class="layout">

<aside class="sidebar" id="sidebar">
  <div class="sidebar__label">Indice</div>
  {% for item in toc %}
  <a href="#{{ item.id }}" class="sidebar__link">{{ item.text }}</a>
  {% endfor %}
</aside>

<main class="main">

<section class="hero">
  <div class="hero__badge">
    <svg width="12" height="12" viewBox="0 0 24 24" fill="currentColor"><circle cx="12" cy="12" r="4"/></svg>
    BYD Club Italia · Community Guide
  </div>
  <h1 class="hero__title">BYD <em>{{ meta.model }}</em></h1>
  <p class="hero__subtitle">
    Guida completa al <strong>downgrade</strong>, <strong>sideload</strong>
    e <strong>upgrade</strong> del firmware Infotainment. Per sbloccare l'installazione
    di APP di terze parti e tornare al firmware più recente.
  </p>
  <div class="hero__meta">
    <div class="hero__meta-item">
      <svg width="14" height="14" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round"><path d="M20 21v-2a4 4 0 0 0-4-4H8a4 4 0 0 0-4 4v2"/><circle cx="12" cy="7" r="4"/></svg>
      <span><strong>Autore:</strong> {{ meta.author }}</span>
    </div>
    <div class="hero__meta-item">
      <svg width="14" height="14" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round"><rect x="3" y="4" width="18" height="18" rx="2"/><line x1="16" y1="2" x2="16" y2="6"/><line x1="8" y1="2" x2="8" y2="6"/><line x1="3" y1="10" x2="21" y2="10"/></svg>
      <span><strong>Versione:</strong> {{ meta.version }} · {{ meta.date }}</span>
    </div>
    {% if meta.editor %}
    <div class="hero__meta-item">
      <svg width="14" height="14" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round"><path d="M12 20h9M16.5 3.5a2.121 2.121 0 1 1 3 3L7 19l-4 1 1-4L16.5 3.5z"/></svg>
      <span><strong>Editing:</strong> {{ meta.editor }}</span>
    </div>
    {% endif %}
  </div>
</section>

{{ body | safe }}

<footer class="footer">
  <div>Guida BYD {{ meta.model }} · v{{ meta.version }} · {{ meta.date }} · <a href="https://t.me/BYDCLUBITALIANews">BYD Club Italia</a></div>
  <div>Documento didattico · Uso a proprio rischio</div>
</footer>

</main>
</div>

<div class="lightbox" id="lightbox"><img id="lightboxImg" alt=""></div>

<script>
const progress = document.getElementById('progress');
window.addEventListener('scroll', () => {
  const h = document.documentElement;
  const scrolled = (h.scrollTop / (h.scrollHeight - h.clientHeight)) * 100;
  progress.style.width = scrolled + '%';
}, { passive: true });

const themeToggle = document.getElementById('themeToggle');
const lightIcon = themeToggle.querySelector('.theme-icon-light');
const darkIcon = themeToggle.querySelector('.theme-icon-dark');
function applyTheme(t) {
  document.documentElement.setAttribute('data-theme', t);
  lightIcon.style.display = t === 'light' ? '' : 'none';
  darkIcon.style.display  = t === 'dark'  ? '' : 'none';
  try { localStorage.setItem('byd-guide-theme', t); } catch(e){}
}
try {
  const saved = localStorage.getItem('byd-guide-theme');
  if (saved) applyTheme(saved);
} catch(e){}
themeToggle.addEventListener('click', () => {
  const cur = document.documentElement.getAttribute('data-theme');
  applyTheme(cur === 'light' ? 'dark' : 'light');
});

// Print button: opens browser print dialog (user saves as PDF)
document.getElementById('printBtn').addEventListener('click', () => {
  // Open all <details> so glossary prints expanded
  document.querySelectorAll('details').forEach(d => d.open = true);
  window.print();
});

const sections = document.querySelectorAll('main h1.chapter[id]');
const navLinks = document.querySelectorAll('.sidebar__link');
function updateActive() {
  let current = '';
  sections.forEach(s => {
    if (window.scrollY >= s.offsetTop - 120) current = s.id;
  });
  navLinks.forEach(l => {
    l.classList.toggle('is-active', l.getAttribute('href') === '#' + current);
  });
}
window.addEventListener('scroll', updateActive, { passive: true });
updateActive();

const sidebar = document.getElementById('sidebar');
document.getElementById('menuToggle').addEventListener('click', () => {
  sidebar.classList.toggle('is-open');
});
navLinks.forEach(l => l.addEventListener('click', () => sidebar.classList.remove('is-open')));

document.querySelectorAll('.code-block__copy').forEach(btn => {
  btn.addEventListener('click', async () => {
    const text = btn.getAttribute('data-copy');
    try {
      await navigator.clipboard.writeText(text);
      const orig = btn.innerHTML;
      btn.classList.add('is-copied');
      btn.innerHTML = '<svg viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2.5" stroke-linecap="round"><polyline points="20 6 9 17 4 12"/></svg> Copiato!';
      setTimeout(() => {
        btn.classList.remove('is-copied');
        btn.innerHTML = orig;
      }, 1500);
    } catch(e) { console.error(e); }
  });
});

document.querySelectorAll('.checklist li').forEach(li => {
  li.addEventListener('click', () => li.classList.toggle('is-checked'));
});

const lightbox = document.getElementById('lightbox');
const lightboxImg = document.getElementById('lightboxImg');
document.querySelectorAll('figure img').forEach(img => {
  img.addEventListener('click', () => {
    lightboxImg.src = img.src;
    lightboxImg.alt = img.alt;
    lightbox.classList.add('is-open');
  });
});
lightbox.addEventListener('click', () => lightbox.classList.remove('is-open'));
document.addEventListener('keydown', (e) => {
  if (e.key === 'Escape') lightbox.classList.remove('is-open');
});
</script>
</body>
</html>
