<!DOCTYPE html>
<html lang="it">
<head>
<meta charset="UTF-8">
<meta name="viewport" content="width=device-width, initial-scale=1.0">
<title>Guide BYD — BYD Club Italia</title>
<meta name="description" content="Guide community alla gestione del firmware dell'infotainment BYD — downgrade, sideload, upgrade per tutti i modelli.">

<link rel="preconnect" href="https://fonts.googleapis.com">
<link rel="preconnect" href="https://fonts.gstatic.com" crossorigin>
<link href="https://fonts.googleapis.com/css2?family=Inter:wght@300;400;500;600;700;800&display=swap" rel="stylesheet">

<style>
:root {
  --bg: #FAFAF9; --bg-elevated: #FFFFFF; --bg-subtle: #F5F5F4;
  --text: #0F172A; --text-muted: #64748B; --text-subtle: #94A3B8;
  --border: #E2E8F0; --accent: #3B82F6; --accent-dark: #1D4ED8;
  --accent-soft: #DBEAFE; --info: #0EA5E9;
  --font-sans: 'Inter', system-ui, sans-serif;
  --shadow: 0 1px 3px rgba(15,23,42,0.06), 0 1px 2px rgba(15,23,42,0.04);
  --shadow-lg: 0 10px 30px rgba(15,23,42,0.08), 0 4px 10px rgba(15,23,42,0.04);
}
* { box-sizing: border-box; }
body { margin: 0; font-family: var(--font-sans); background: var(--bg);
  color: var(--text); -webkit-font-smoothing: antialiased; line-height: 1.6; }
a { color: var(--accent); text-decoration: none; }
a:hover { color: var(--accent-dark); }

.wrap { max-width: 1080px; margin: 0 auto; padding: 48px 32px 96px; }

.hero { text-align: center; margin-bottom: 64px; }
.hero__logo {
  display: block;
  width: 160px;
  height: auto;
  margin: 0 auto 24px;
  border-radius: 18px;
  box-shadow: var(--shadow-lg);
}
@media (max-width: 640px) {
  .hero__logo { width: 130px; }
}
.hero h1 {
  font-size: 56px; font-weight: 800; letter-spacing: -0.03em;
  margin: 0 0 16px; line-height: 1.1;
}
.hero p {
  font-size: 19px; color: var(--text-muted); max-width: 620px;
  margin: 0 auto 32px; line-height: 1.5;
}
.hero__badge {
  display: inline-flex; align-items: center; gap: 8px;
  background: var(--accent-soft); color: var(--accent-dark);
  padding: 6px 14px; border-radius: 100px; font-size: 13px;
  font-weight: 600; letter-spacing: 0.02em;
}
.hero__badge::before {
  content: ''; width: 6px; height: 6px; border-radius: 50%;
  background: var(--info); display: inline-block;
}

.grid { display: grid; grid-template-columns: repeat(auto-fill, minmax(300px, 1fr));
  gap: 24px; margin-bottom: 64px; }

.guide-card {
  background: var(--bg-elevated); border: 1px solid var(--border);
  border-radius: 16px; padding: 28px 28px 24px;
  box-shadow: var(--shadow); transition: all 0.2s;
  display: flex; flex-direction: column;
  text-decoration: none; color: inherit;
  position: relative; overflow: hidden;
}
.guide-card::before {
  content: ''; position: absolute; top: 0; left: 0; right: 0; height: 4px;
  background: linear-gradient(90deg, var(--accent), var(--info));
  opacity: 0; transition: opacity 0.2s;
}
.guide-card:hover {
  transform: translateY(-3px); box-shadow: var(--shadow-lg);
  border-color: var(--accent); text-decoration: none;
}
.guide-card:hover::before { opacity: 1; }
.guide-card__header {
  display: flex; justify-content: space-between; align-items: center;
  margin-bottom: 6px; min-height: 20px;
}
.guide-card__model {
  font-size: 11px; font-weight: 700; letter-spacing: 0.08em;
  color: var(--text-subtle); text-transform: uppercase;
}
.guide-card__badge {
  font-size: 10px; font-weight: 700; letter-spacing: 0.06em;
  text-transform: uppercase; padding: 3px 8px;
  background: var(--accent-soft); color: var(--accent-dark);
  border-radius: 100px;
}
.guide-card__title {
  font-size: 26px; font-weight: 800; letter-spacing: -0.02em;
  margin: 0 0 10px; color: var(--text);
}
.guide-card__desc {
  font-size: 14px; color: var(--text-muted);
  line-height: 1.55; margin-bottom: 20px; flex-grow: 1;
}
.guide-card__meta {
  display: flex; justify-content: space-between; align-items: center;
  padding-top: 16px; border-top: 1px solid var(--border);
  font-size: 12px; color: var(--text-subtle);
}
.guide-card__cta {
  display: inline-flex; align-items: center; gap: 6px;
  color: var(--accent); font-weight: 600; font-size: 13px;
}
.guide-card__cta svg { width: 14px; height: 14px; transition: transform 0.15s; }
.guide-card:hover .guide-card__cta svg { transform: translateX(3px); }

.section-title {
  font-size: 14px; text-transform: uppercase; letter-spacing: 0.08em;
  font-weight: 700; color: var(--text-subtle); margin: 48px 0 20px;
}

.info-grid { display: grid; grid-template-columns: repeat(auto-fit, minmax(260px, 1fr));
  gap: 20px; margin-bottom: 48px; }
.info-card {
  background: var(--bg-elevated); border: 1px solid var(--border);
  border-radius: 12px; padding: 20px 22px;
}
.info-card h3 { font-size: 15px; font-weight: 700; margin: 0 0 8px;
  display: flex; align-items: center; gap: 8px; }
.info-card p { margin: 0; color: var(--text-muted); font-size: 14px; }
.info-card__icon {
  width: 32px; height: 32px; border-radius: 8px;
  background: var(--accent-soft); color: var(--accent);
  display: inline-flex; align-items: center; justify-content: center;
}
.info-card__icon svg { width: 16px; height: 16px; }

.footer {
  margin-top: 80px; padding-top: 32px; border-top: 1px solid var(--border);
  text-align: center; color: var(--text-subtle); font-size: 13px;
}
.social {
  margin-bottom: 32px; padding-bottom: 32px;
  border-bottom: 1px solid var(--border);
}
.social__label {
  font-size: 13px; text-transform: uppercase; letter-spacing: 0.08em;
  font-weight: 700; color: var(--text-muted); margin-bottom: 16px;
}
.social__list {
  display: flex; justify-content: center; gap: 14px; flex-wrap: wrap;
}
.social__link {
  display: inline-flex; align-items: center; justify-content: center;
  width: 44px; height: 44px; border-radius: 50%;
  background: var(--bg-elevated); border: 1px solid var(--border);
  color: var(--text-muted); transition: all 0.2s;
  box-shadow: var(--shadow);
}
.social__link svg { width: 20px; height: 20px; }
.social__link:hover {
  transform: translateY(-3px) scale(1.05);
  box-shadow: var(--shadow-lg);
  color: #fff;
  text-decoration: none;
}
.social__link--telegram:hover  { background: #229ED9; border-color: #229ED9; }
.social__link--facebook:hover  { background: #1877F2; border-color: #1877F2; }
.social__link--youtube:hover   { background: #FF0000; border-color: #FF0000; }
.social__link--instagram:hover { background: linear-gradient(45deg, #F58529, #DD2A7B, #8134AF, #515BD4); border-color: #DD2A7B; }
.social__link--x:hover   { background: #000000; border-color: #000000; }

@media (max-width: 640px) {
  .wrap { padding: 32px 20px 64px; }
  .hero h1 { font-size: 38px; }
  .hero p { font-size: 16px; }
  .guide-card { padding: 22px; }
  .guide-card__title { font-size: 22px; }
}
</style>
</head>
<body>

<div class="wrap">

<div class="hero">
  <!-- Logo community: inlinato in base64 da build.py. Per cambiarlo, sostituisci
     il file images/common/logo-community.jpg mantenendo path e nome identici. -->
<img class="hero__logo" src="{{ logo_src }}" alt="BYD Club Italia">
  <div class="hero__badge">BYD Club Italia · Community Guides</div>
  <h1>Guide BYD</h1>
  <p>
    Procedure della community per <strong>downgrade</strong>, <strong>sideload</strong> e
    <strong>upgrade</strong> dell'infotainment e guide extra. Sblocca l'installazione di APP di terze
    parti sul tuo veicolo BYD e mantieni il sistema sempre aggiornato.
  </p>
</div>

<div class="section-title">Guide disponibili</div>

<div class="grid">
  {% for g in guides %}
  <a class="guide-card" href="{{ g.slug }}.html">
    <div class="guide-card__header">
      {% if g.model_prefix %}<div class="guide-card__model">{{ g.model_prefix }}</div>{% endif %}
      {% if g.category %}<span class="guide-card__badge">{{ g.category }}</span>{% endif %}
    </div>
    <h2 class="guide-card__title">{{ g.title }}</h2>
    <p class="guide-card__desc">
      {{ g.card_description | default("Guida della community BYD Club Italia.", true) }}
    </p>
    <div class="guide-card__meta">
      <span>v{{ g.version }} · {{ g.chapters }} capitoli</span>
      <span class="guide-card__cta">
        Leggi
        <svg viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round"><line x1="5" y1="12" x2="19" y2="12"/><polyline points="12 5 19 12 12 19"/></svg>
      </span>
    </div>
  </a>
  {% endfor %}
</div>

<div class="section-title">Come usare le guide</div>

<div class="info-grid">
  <div class="info-card">
    <div class="info-card__icon">
      <svg viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round"><rect x="2" y="3" width="20" height="14" rx="2"/><line x1="8" y1="21" x2="16" y2="21"/><line x1="12" y1="17" x2="12" y2="21"/></svg>
    </div>
    <h3>Lettura online</h3>
    <p>Sempre aggiornata. Apri il link nel browser del tuo PC o del telefono.</p>
  </div>
  <div class="info-card">
    <div class="info-card__icon">
      <svg viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round"><path d="M21 15v4a2 2 0 0 1-2 2H5a2 2 0 0 1-2-2v-4"/><polyline points="7 10 12 15 17 10"/><line x1="12" y1="15" x2="12" y2="3"/></svg>
    </div>
    <h3>Scarica in PDF</h3>
    <p>Ogni guida ha un tasto di stampa in alto a destra per salvare una copia PDF.</p>
  </div>
  <div class="info-card">
    <div class="info-card__icon">
      <svg viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round"><circle cx="12" cy="12" r="10"/><polyline points="12 6 12 12 16 14"/></svg>
    </div>
    <h3>Sempre aggiornata</h3>
    <p>Mantenuta dalla community. Condividi sempre questo link, non PDF vecchi.</p>
  </div>
</div>

<footer class="footer">

  <!-- =====================================================================
       SEZIONE SOCIAL — MODIFICA QUI per cambiare i link ai social della community
       Ogni <a href="..."> ha accanto un commento che indica quale social è.
       ===================================================================== -->
  <div class="social">
    <div class="social__label">Seguici su</div>
    <div class="social__list">

      <!-- TELEGRAM: canale news -->
      <a class="social__link social__link--telegram"
         href="https://t.me/BYD_CLUB_ITALIA"
         target="_blank" rel="noopener"
         aria-label="Telegram BYD Club Italia">
        <svg viewBox="0 0 24 24" fill="currentColor" aria-hidden="true">
          <path d="M9.78 18.65l.28-4.23 7.68-6.92c.34-.31-.07-.46-.52-.19L7.74 13.3 3.64 12c-.88-.25-.89-.86.2-1.3l15.97-6.16c.73-.33 1.43.18 1.15 1.3l-2.72 12.81c-.19.91-.74 1.13-1.5.71L12.6 16.3l-1.99 1.93c-.23.23-.42.42-.83.42z"/>
        </svg>
      </a>

      <!-- FACEBOOK: MODIFICA QUI con l'URL della pagina FB della community -->
      <a class="social__link social__link--facebook"
         href="https://www.facebook.com/groups/1281956122671032/"
         target="_blank" rel="noopener"
         aria-label="Facebook BYD Club Italia">
        <svg viewBox="0 0 24 24" fill="currentColor" aria-hidden="true">
          <path d="M24 12.073c0-6.627-5.373-12-12-12s-12 5.373-12 12c0 5.99 4.388 10.954 10.125 11.854v-8.385H7.078v-3.47h3.047V9.43c0-3.007 1.792-4.669 4.533-4.669 1.312 0 2.686.235 2.686.235v2.953H15.83c-1.491 0-1.956.925-1.956 1.874v2.25h3.328l-.532 3.47h-2.796v8.385C19.612 23.027 24 18.062 24 12.073z"/>
        </svg>
      </a>

      <!-- YOUTUBE: MODIFICA QUI con l'URL del canale YT della community -->
      <a class="social__link social__link--youtube"
         href="http://www.youtube.com/@BYDCLUBITALIA"
         target="_blank" rel="noopener"
         aria-label="YouTube BYD Club Italia">
        <svg viewBox="0 0 24 24" fill="currentColor" aria-hidden="true">
          <path d="M23.498 6.186a3.016 3.016 0 0 0-2.122-2.136C19.505 3.545 12 3.545 12 3.545s-7.505 0-9.377.505A3.017 3.017 0 0 0 .502 6.186C0 8.07 0 12 0 12s0 3.93.502 5.814a3.016 3.016 0 0 0 2.122 2.136c1.871.505 9.376.505 9.376.505s7.505 0 9.377-.505a3.015 3.015 0 0 0 2.122-2.136C24 15.93 24 12 24 12s0-3.93-.502-5.814zM9.545 15.568V8.432L15.818 12l-6.273 3.568z"/>
        </svg>
      </a>

      <!-- INSTAGRAM: MODIFICA QUI con l'URL del profilo IG della community -->
      <a class="social__link social__link--instagram"
         href="https://www.instagram.com/byd_club_italia/"
         target="_blank" rel="noopener"
         aria-label="Instagram BYD Club Italia">
        <svg viewBox="0 0 24 24" fill="currentColor" aria-hidden="true">
          <path d="M12 2.163c3.204 0 3.584.012 4.85.07 3.252.148 4.771 1.691 4.919 4.919.058 1.265.069 1.645.069 4.849 0 3.205-.012 3.584-.069 4.849-.149 3.225-1.664 4.771-4.919 4.919-1.266.058-1.644.07-4.85.07-3.204 0-3.584-.012-4.849-.07-3.26-.149-4.771-1.699-4.919-4.92-.058-1.265-.07-1.644-.07-4.849 0-3.204.013-3.583.07-4.849.149-3.227 1.664-4.771 4.919-4.919 1.266-.057 1.645-.069 4.849-.069zM12 0C8.741 0 8.333.014 7.053.072 2.695.272.273 2.69.073 7.052.014 8.333 0 8.741 0 12c0 3.259.014 3.668.072 4.948.2 4.358 2.618 6.78 6.98 6.98C8.333 23.986 8.741 24 12 24c3.259 0 3.668-.014 4.948-.072 4.354-.2 6.782-2.618 6.979-6.98.059-1.28.073-1.689.073-4.948 0-3.259-.014-3.667-.072-4.947-.196-4.354-2.617-6.78-6.979-6.98C15.668.014 15.259 0 12 0zm0 5.838a6.162 6.162 0 1 0 0 12.324 6.162 6.162 0 0 0 0-12.324zM12 16a4 4 0 1 1 0-8 4 4 0 0 1 0 8zm6.406-11.845a1.44 1.44 0 1 0 0 2.881 1.44 1.44 0 0 0 0-2.881z"/>
        </svg>
      </a>

			<!-- X: MODIFICA QUI con l'URL del profilo X della community -->
      <a class="social__link social__link--x"
         href="https://x.com/bydclubitalia"
         target="_blank" rel="noopener"
         aria-label="Instagram BYD Club Italia">
        <svg viewBox="0 0 24 24" fill="currentColor" aria-hidden="true">
          <path d="M14.234 10.162 22.977 0h-2.072l-7.591 8.824L7.251 0H.258l9.168 13.343L.258 24H2.33l8.016-9.318L16.749 24h6.993zm-2.837 3.299-.929-1.329L3.076 1.56h3.182l5.965 8.532.929 1.329 7.754 11.09h-3.182z"/>
        </svg>
      </a>

    </div>
  </div>
  <!-- =====================================================================
       FINE SEZIONE SOCIAL
       ===================================================================== -->

  <p>
    Mantenute da <strong>BYD Club Italia</strong> ·
    <a href="https://github.com/BYD-Club-Italia/byd-club-italia-guides">Contribuisci su GitHub</a>
  </p>
  <p style="margin-top:8px; font-size:12px;">Documenti didattici. Uso a proprio rischio.</p>
</footer>

</div>

</body>
</html>